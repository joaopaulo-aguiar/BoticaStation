{
  "name": "boticastation",
  "private": true,
  "version": "0.37.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:infra": "tsc -p infra/tsconfig.json",
    "preview": "vite preview",
    "test": "jest --testPathPattern='unit|integration'",
    "test:unit": "jest --testPathPattern='unit'",
    "test:int": "jest --testPathPattern='integration'",
    "test:e2e": "jest --testPathPattern='e2e'",
    "test:watch": "jest --watch --testPathPattern='unit'",
    "test:coverage": "jest --coverage --testPathPattern='unit|integration'",
    "lint": "eslint src scripts __tests__ --ext .ts",
    "diff": "cdk diff --all",
    "deploy": "cdk deploy --all --require-approval never",
    "migrate": "ts-node migrations/dynamodb/runner.ts up",
    "migrate:status": "ts-node migrations/dynamodb/runner.ts status",
    "sync-docs": "ts-node scripts/sync-aws-docs.ts"
  },
  "dependencies": {
    "@aws-sdk/client-amplify": "^3.700.0",
    "@aws-sdk/client-appsync": "^3.700.0",
    "@aws-sdk/client-cloudformation": "^3.700.0",
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-ecr": "^3.700.0",
    "@aws-sdk/client-ecs": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@aws-sdk/client-sfn": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.72.2",
    "aws-amplify": "^6.14.4",
    "aws-cdk-lib": "^2.175.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "constructs": "^10.4.2",
    "emmet-monaco-es": "^5.7.0",
    "lucide-react": "^0.575.0",
    "papaparse": "^5.5.3",
    "parse5": "^8.0.0",
    "prettier": "^3.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^3.1.0",
    "source-map-support": "^0.5.21",
    "tailwind-merge": "^3.3.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/papaparse": "^5.5.2",
    "@types/parse5": "^6.0.3",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.5.2",
    "aws-cdk": "^2.175.0",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "tailwindcss": "^4.1.8",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
